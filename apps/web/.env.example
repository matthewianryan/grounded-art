# Base URL of the Grounded Art read API. Defaults to the local API when unset.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Google Maps JavaScript API key for the map base layer. This is a browser key by nature, so it
# is exposed to the client; restrict it by HTTP referrer and to the Maps JavaScript API in the
# Google Cloud console. The map page treats an unset key as "map not configured" and degrades
# gracefully. See docs/external-dependencies.md for the provider boundary and decoupling path.
#
# Local dev referrers to allow (Application restrictions > HTTP referrers):
#   http://localhost:3000/*
#   http://localhost:3001/*
# The landing app proxies /app to the web app on 3001, but the browser referer stays on 3000.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
