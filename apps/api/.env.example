# Database connection.
#
# Local development (the Docker Compose Postgres):
DATABASE_URL=postgresql+psycopg://grounded:grounded@localhost:5432/grounded_art
#
# Deployed environments: set DATABASE_URL to the platform's connection string. A managed
# provider's postgres:// or postgresql:// URL is accepted and normalized to the psycopg driver
# automatically. Append ?sslmode=require when the provider requires TLS, for example:
#   DATABASE_URL=postgresql://user:pass@db.example.com:5432/grounded_art?sslmode=require

# CORS origins allowed to call the API from a browser, as a JSON array. Defaults to the local
# web and landing dev servers. Set this to the deployed web app origin in production.
# CORS_ORIGINS=["https://www.grounded-art.co.za"]
