{
  "name": "grounded-art",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.18.1",
  "scripts": {
    "dev": "turbo run dev",
    "dev:local": "node tooling/dev-local.mjs",
    "build": "turbo run build",
    "pages:build": "pnpm --filter @grounded-art/landing pages:build",
    "pages:preview": "pnpm --filter @grounded-art/landing pages:preview",
    "pages:deploy": "pnpm pages:build && cd apps/landing && npx wrangler pages deploy out --project-name=grounded-art-landing",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp", "workerd"]
  }
}
