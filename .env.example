# Local development defaults. Copy this file to .env at the repo root and fill in keys.

# API and database
DATABASE_URL=postgresql+psycopg://grounded:grounded@localhost:5432/grounded_art
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","https://grounded-art.co.za","https://www.grounded-art.co.za","https://app.grounded-art.co.za"]
REDESIGN_SCHEMA_ENABLED=true

# Public app origin linked from the static landing. Local dev points at the web app on :3001.
# The production Cloudflare Pages build (pnpm pages:build) defaults this to
# https://app.grounded-art.co.za, so the deployed landing never links to localhost.
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Is the standalone web app (Map, Feed) actually deployed and serving? While this is unset or
# "false", the landing's Map/Feed links stay on the landing and scroll to the on-page explainer
# sections (#atlas, #feed). Flip to "true" once app.grounded-art.co.za is live to route those
# links at the real app instead. This is the single flag to flip at launch.
NEXT_PUBLIC_APP_LIVE=false

# Browser-visible frontend config.
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_COOKIE_PATH=/
WEB_SESSION_COOKIE_PATH=/

# Docker reverse proxy. Keep these local values for development; set real hostnames on xneelo.
APP_HOST=:80
API_HOST=api.localhost
DB_PORT=5432
API_PORT=8000
CADDY_HTTP_PORT=8080
CADDY_HTTPS_PORT=8443
WEB_PORT=3001
ACME_EMAIL=hello@grounded-art.co.za

# Contact email notifications through Resend.
RESEND_API_KEY=
RESEND_API_URL=https://api.resend.com/emails
CONTACT_NOTIFICATION_TO=hello@grounded-art.co.za
CONTACT_NOTIFICATION_FROM="Grounded Art <notifications@grounded-art.co.za>"
CONTACT_NOTIFICATION_REPLY_TO_SUBMITTER=true

# Contact abuse guardrails.
CONTACT_RATE_LIMIT_IP_MAX=5
CONTACT_RATE_LIMIT_IP_WINDOW_SECONDS=900
CONTACT_RATE_LIMIT_EMAIL_MAX=3
CONTACT_RATE_LIMIT_EMAIL_WINDOW_SECONDS=3600

# Optional Cloudflare Turnstile. Leave both blank until spam makes it necessary.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_SITEVERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify

# Auth and session.
SESSION_TTL_DAYS=30
LOGIN_CODE_TTL_MINUTES=10
LOGIN_CODE_PEPPER=dev-pepper-change-in-production
LOGIN_CODE_MAX_ATTEMPTS=5
LOGIN_CODE_RATE_LIMIT_PER_EMAIL=3
LOGIN_CODE_RATE_LIMIT_WINDOW_HOURS=1
EMAIL_PROVIDER=console
EMAIL_FROM="Grounded Art <noreply@grounded-art.co.za>"
COOKIE_SECURE=false
SESSION_COOKIE_NAME=ga-session
SESSION_COOKIE_PATH=/

# Check-in verification and wallet awards.
CHECK_IN_RADIUS_METRES=100
CHECK_IN_CHALLENGE_TTL_MINUTES=5
CHECK_IN_AWARD_WINDOW_HOURS=24
